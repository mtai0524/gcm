<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="gcm"
      Manufacturer="devduide"
      Version="$(Version)"
      UpgradeCode="86B66A85-F6A0-4061-AE53-8F52B10FC1BD"
      Scope="perUser"
      Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of gcm is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Giao dien cai dat: Welcome -> License -> Progress -> Finish -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="packaging/windows/License.rtf" />

    <!-- Thong tin hien trong Add/Remove Programs -->
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/mtai0524/gcm" />
    <Property Id="ARPHELPLINK" Value="https://github.com/mtai0524/gcm" />

    <!-- Cai vao thu muc user: %LocalAppData%\Programs\gcm (khong can admin) -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="gcm">
          <Component Id="GcmExe" Bitness="always64">
            <File Id="GcmExeFile" Source="dist/gcm.exe" KeyPath="yes" />
          </Component>
          <Component Id="GcmPath" Guid="ABB8F2A6-399B-4846-A72C-259FDCAB3A06" Bitness="always64">
            <!-- System="no" -> ghi vao PATH cua USER (HKCU), khong can admin -->
            <Environment Id="PathEnv" Name="PATH" Value="[INSTALLFOLDER]"
                         Part="last" Action="set" System="no" Permanent="no" />
          </Component>
          <Component Id="GcmSetupScript" Bitness="always64">
            <File Id="GcmSetupScriptFile" Source="packaging/windows/setup-profile.ps1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="gcm" Level="1">
      <ComponentRef Id="GcmExe" />
      <ComponentRef Id="GcmPath" />
      <ComponentRef Id="GcmSetupScript" />
    </Feature>

    <!-- Cau hinh lenh 'gcm' trong PowerShell profile (ghi de alias Get-Command).
         Chay setup-profile.ps1 da cai; dung $env:LOCALAPPDATA nen khong can
         resolve [INSTALLFOLDER] trong ngu canh deferred. -->
    <CustomAction Id="GcmAddProfile"
        Directory="INSTALLFOLDER"
        ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; '$env:LOCALAPPDATA\Programs\gcm\setup-profile.ps1' install&quot;"
        Execute="deferred" Impersonate="yes" Return="ignore" />
    <CustomAction Id="GcmRemoveProfile"
        Directory="INSTALLFOLDER"
        ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; '$env:LOCALAPPDATA\Programs\gcm\setup-profile.ps1' uninstall&quot;"
        Execute="deferred" Impersonate="yes" Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="GcmAddProfile" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="GcmRemoveProfile" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>
  </Package>
</Wix>
