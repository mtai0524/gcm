# ---- small terminal color helpers ----
def c(text, code):
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"


def err(msg):
    print(c("error: ", "31") + msg, file=sys.stderr)


def run_git(args, check=True):
    """Run a git command, return stdout (stripped)."""
    res = subprocess.run(
        ["git"] + args,
        capture_output=True, text=True,
        encoding="utf-8", errors="replace",
        cwd=REPO_ROOT,
    )
    if check and res.returncode != 0:
        err(res.stderr.strip() or f"git {' '.join(args)} failed")
        sys.exit(1)
    return res.stdout


def get_api_key():
    key = os.environ.get("GROQ_API_KEY", "").strip() or CONFIG.get("api_key", "")
    if key:
        return key
    err("no Groq API key found.")
    print(
        "  Lay key free tai: " + c("https://console.groq.com/keys", "36"),
        file=sys.stderr,
    )
    print("  Roi chay mot trong hai cach:", file=sys.stderr)
    print('    export GROQ_API_KEY="gsk_..."   (them vao ~/.bashrc)', file=sys.stderr)
    print(f'    echo "gsk_..." > {CONFIG_PATH}', file=sys.stderr)
    sys.exit(1)


def ensure_repo():
    global REPO_ROOT
    res = subprocess.run(
        ["git", "rev-parse", "--is-inside-work-tree", "--show-toplevel"],
        capture_output=True, text=True,
        encoding="utf-8", errors="replace",
    )
    lines = res.stdout.splitlines()
    if res.returncode != 0 or not lines or lines[0].strip() != "true":
        err("khong phai git repository (chay trong thu muc repo).")
        sys.exit(1)
    REPO_ROOT = lines[1].strip() if len(lines) > 1 else None


def changed_files():
    items = []
    for line in run_git(["status", "--porcelain", "-uall"]).splitlines():
        if not line.strip():
            continue
        code = line[:2]
        rest = line[3:]
        if " -> " in rest:
            rest = rest.split(" -> ", 1)[1]
        rest = rest.strip()
        if len(rest) >= 2 and rest[0] == '"' and rest[-1] == '"':
            rest = rest[1:-1].encode().decode("unicode_escape")
        items.append((code, rest))
    return items


def status_label(code):
    if code == "??":
        return c("new      ", "36")
    flags = code.replace(" ", "")
    if "D" in flags:
        return c("deleted  ", "31")
    if "R" in flags:
        return c("renamed  ", "35")
    if "A" in flags:
        return c("added    ", "32")
    if "M" in flags:
        return c("modified ", "33")
    return c(code.ljust(9), "90")


def parse_selection(raw, n):
    chosen = set()
    for tok in raw.replace(",", " ").split():
        if "-" in tok:
            a, _, b = tok.partition("-")
            if a.isdigit() and b.isdigit():
                for k in range(int(a), int(b) + 1):
                    if 1 <= k <= n:
                        chosen.add(k)
        elif tok.isdigit():
            k = int(tok)
            if 1 <= k <= n:
                chosen.add(k)
    return sorted(chosen)


def select_files(default_all=False):
    items = changed_files()
    if not items:
        return False
    n = len(items)
    print(c(f"Chon file de stage ({n} thay doi):", "1"))
    for i, (code, path) in enumerate(items, 1):
        staged = code[0] not in " ?"
        mark = c("\u25cf", "32") if staged else c("\u25cb", "90")
        print(f"  {mark} {c(str(i).rjust(2) + '.', '1')} {status_label(code)} {path}")
    enter_hint = "Enter = tat ca" if default_all else "Enter = giu nguyen"
    print(c(
        f"  so ('1 3', '1-3') . 'a' tat ca . {enter_hint} . 'q' huy",
        "90",
    ))
    try:
        raw = input(c("> ", "1")).strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(1)

    if raw in ("q", "quit", "n"):
        print("Da huy.")
        sys.exit(0)
    if raw == "" and not default_all:
        return False
    if raw in ("a", "all") or (raw == "" and default_all):
        sel = list(range(1, n + 1))
    else:
        sel = parse_selection(raw, n)
    if not sel:
        err("khong chon file nao hop le.")
        sys.exit(1)
    paths = [items[i - 1][1] for i in sel]
    run_git(["add", "--"] + paths)
    print(c(f"da stage {len(paths)} file.", "32"))
    return True


def tui_supported():
    """TUI cần stdin/stdout là tty và có module đọc phím raw."""
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        return False
    try:
        if os.name == "nt":
            import msvcrt  # noqa: F401
        else:
            import termios, tty  # noqa: F401
        return True
    except ImportError:
        return False


def _map_key(ch):
    if ch in ("\r", "\n"):
        return "enter"
    if ch == " ":
        return "space"
    if ch in ("k", "K"):
        return "up"
    if ch in ("j", "J"):
        return "down"
    if ch in ("a", "A"):
        return "all"
    if ch in ("d", "D"):
        return "diff"
    if ch in ("q", "Q", "\x03", "\x1b"):
        return "quit"
    return ""


def read_key():
    """Đọc 1 phím, trả token: up/down/space/enter/all/quit hoặc ''."""
    if os.name == "nt":
        import msvcrt
        ch = msvcrt.getch()
        if ch in (b"\x00", b"\xe0"):  # phím mũi tên: prefix rồi mã
            return {b"H": "up", b"P": "down"}.get(msvcrt.getch(), "")
        return _map_key(ch.decode("latin-1", "ignore"))
    import termios, tty
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
        if ch == "\x1b":  # ESC hoặc chuỗi mũi tên \x1b[A
            seq = sys.stdin.read(2)
            return {"[A": "up", "[B": "down"}.get(seq, "quit")
        return _map_key(ch)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def show_file_diff(code, path, max_lines=40):
    """In diff (co mau) cua 1 file trong picker; file moi thi in noi dung."""
    print()
    if code == "??":
        try:
            full = os.path.join(REPO_ROOT or ".", path)
            with open(full, encoding="utf-8", errors="replace") as f:
                body = f.read(8000)
        except OSError as e:
            body = f"(khong doc duoc: {e})"
        print(c(f"--- {path} (file moi) ---", "1"))
        lines = body.splitlines() or ["(file rong)"]
    else:
        d = run_git(["diff", "--color", "HEAD", "--", path], check=False)
        print(c(f"--- diff {path} ---", "1"))
        lines = d.rstrip().splitlines() or ["(khong co thay doi)"]
    print("\n".join(lines[:max_lines]))
    if len(lines) > max_lines:
        print(c(f"... ({len(lines) - max_lines} dong nua)", "90"))
    print(c("nhan phim bat ky de quay lai...", "90"))
    read_key()


def tui_select(default_all=False):
    """Bộ chọn file kiểu TUI: ↑↓ di chuyển, space chọn, d xem diff, enter xong."""
    items = changed_files()
    if not items:
        return False
    n = len(items)
    branch, _ = branch_status()
    selected = {i for i, (code, _) in enumerate(items) if code[0] not in " ?"}
    if default_all and not selected:
        selected = set(range(n))
    cursor = 0
    rendered = 0

    def draw():
        nonlocal rendered
        if rendered:
            sys.stdout.write(f"\033[{rendered}A")  # quay lên đầu khối
        lines = [
            c(f"[{branch}] Chon file de stage ({len(selected)}/{n})", "1")
            + c("  ↑↓ chon . space tick . d diff . a tat ca . enter xong . q huy",
                "90"),
        ]
        for i, (code, path) in enumerate(items):
            box = c("[x]", "32") if i in selected else "[ ]"
            pointer = c(">", "36") if i == cursor else " "
            lines.append(f" {pointer} {box} {status_label(code)} {path}")
        sys.stdout.write("\n".join("\033[2K" + ln for ln in lines) + "\n")
        sys.stdout.flush()
        rendered = len(lines)

    while True:
        draw()
        key = read_key()
        if key == "up":
            cursor = (cursor - 1) % n
        elif key == "down":
            cursor = (cursor + 1) % n
        elif key == "space":
            selected ^= {cursor}
        elif key == "all":
            selected = set() if len(selected) == n else set(range(n))
        elif key == "diff":
            show_file_diff(*items[cursor])
            rendered = 0  # menu cu da troi len, ve lai menu moi
        elif key == "enter":
            break
        elif key == "quit":
            print("Da huy.")
            sys.exit(0)

    if not selected:
        err("khong chon file nao.")
        sys.exit(1)
    paths = [items[i][1] for i in sorted(selected)]
    run_git(["add", "--"] + paths)
    print(c(f"da stage {len(paths)} file.", "32"))
    return True


SKIP_NAMES = {
    "package-lock.json", "yarn.lock", "pnpm-lock.yaml", "poetry.lock",
    "Cargo.lock", "composer.lock", "Gemfile.lock", "go.sum", "bun.lockb",
    "packages.lock.json",
}
SKIP_SUFFIXES = (".min.js", ".min.css", ".map", ".lock")


def is_noise_file(path):
    """File lockfile/generated: van commit nhung khong gui noi dung cho LLM."""
    name = os.path.basename(path)
    return name in SKIP_NAMES or name.endswith(SKIP_SUFFIXES)


def file_diff(path, from_head=False):
    if from_head:
        return run_git(["show", "--format=", "HEAD", "--", path])
    return run_git(["diff", "--staged", "--", path])


def file_stat(path, from_head=False):
    if from_head:
        return run_git(["show", "--format=", "--stat", "HEAD", "--", path])
    return run_git(["diff", "--staged", "--stat", "--", path])


def smart_diff(files, from_head=False):
    """Gom diff tung file theo budget MAX_DIFF_CHARS.

    - lockfile/generated/binary -> chi ghi ten vao 'skipped' (khong gui noi dung)
    - file qua lon so voi budget con lai -> thay bang --stat cua file do
    Tra (diff_text, skipped_list, truncated_flag).
    """
    parts, skipped = [], []
    remaining = MAX_DIFF_CHARS
    truncated = False
    for f in files:
        if is_noise_file(f):
            skipped.append(f"{f} (lockfile/generated)")
            continue
        d = file_diff(f, from_head)
        if "\nBinary files " in "\n" + d:
            skipped.append(f"{f} (binary)")
            continue
        if len(d) > remaining:
            stat = file_stat(f, from_head).strip()
            entry = f"(diff for {f} too large - stats only)\n{stat}\n\n"
            truncated = True
            if len(entry) <= remaining:
                parts.append(entry)
                remaining -= len(entry)
            else:
                skipped.append(f"{f} (too large)")
            continue
        parts.append(d)
        remaining -= len(d)
    return "".join(parts), skipped, truncated


def build_prompt(diff, files, vietnamese, hint=None, skipped=None):
    lang = (
        "Viet bang TIENG VIET." if vietnamese
        else "Write in ENGLISH."
    )
    files_list = "\n".join(files) if files else "(unknown)"
    system = (
        "You are an expert developer writing git commit messages. "
        "Follow the Conventional Commits spec strictly: "
        "type(scope): short summary in imperative mood. "
        "Allowed types: feat, fix, docs, style, refactor, perf, test, "
        "build, ci, chore, revert. "
        # ---- summary line rules ----
        "IMPORTANT - summary line rules: "
        "Read the ENTIRE diff to understand the overall intent of the change. "
        "Format strictly as 'type(scope): summary'. "
        # ---- scope ----
        "The scope is a SHORT feature/module/domain name in kebab-case, derived "
        "from WHAT the change is about - e.g. 'qc-nav', 'qc-role', 'activity', "
        "'auth', 'menu-bar'. Derive it from the feature or domain area, NEVER "
        "from a raw file name, path, or class name. Use a single scope; if the "
        "change spans several areas pick the dominant one, or omit the scope "
        "entirely (just 'type: summary'). "
        # ---- summary text ----
        "The summary describes the functional intent in plain language (aim "
        "50-72 chars, hard max 100): say WHAT the change accomplishes or what "
        "behaviour it adds/fixes, NOT which files were edited. "
        "Do NOT put file names, component names, or low-level identifiers "
        "(props, variables, endpoints) in the summary - those belong in the body. "
        "GOOD examples - match this exact style: "
        "'fix(qc-nav): persist QC nav group expand/collapse state across navigation', "
        "'refactor(qc-role): sync UI with QC user-management V2 and add audit logging', "
        "'feat(activity): track QC data-input, approval and measurement events', "
        "'feat(qc): add object and IP columns'. "
        # ---- body rules ----
        "Then add a blank line and a DETAILED body of bullet points (each "
        "starting with '- '), in the style of GitHub Copilot commit messages. "
        "Write ONE bullet per distinct, concrete change you can see in the diff "
        "- e.g. a renamed function, a changed API endpoint, a removed button, "
        "an updated constant, a new prop, a deleted block. "
        "Use as many bullets as needed to cover every meaningful change "
        "(typically 3-8; more for large diffs), so a reviewer understands what "
        "changed without reading the diff. "
        "Start each bullet with a past-tense verb (Added, Removed, Updated, "
        "Renamed, Fixed, Refactored, Moved, ...) and name the specific function, "
        "component, file, variable, or value involved. "
        "Group bullets loosely by area/file when there are many. "
        "GOOD bullet examples: "
        "'- Removed unused buttons for toggling bubble and controls menus', "
        "'- Updated API endpoint for file upload to /api/v2/files', "
        "'- Renamed handleMouseMove to set a fixed left position'. "
        "Do NOT invent changes absent from the diff, and do NOT pad with vague "
        "filler like 'for better readability' or 'improve UX' unless tied to a "
        "concrete reason visible in the diff. "
        "Omit the body ONLY for truly trivial one-line changes (typo, version "
        "bump, etc). "
        f"{lang} "
        "Output ONLY the commit message, no markdown fences, no preamble."
    )
    hint_block = (
        f"Extra context from the author (use it, it is important):\n{hint}\n\n"
        if hint else ""
    )
    skipped_block = (
        "Also changed, but content omitted (lockfiles/binary - mention "
        "briefly in the body only if relevant):\n"
        + "\n".join(f"- {s}" for s in skipped) + "\n\n"
        if skipped else ""
    )
    user = (
        f"{hint_block}"
        f"{skipped_block}"
        f"Changed files:\n{files_list}\n\n"
        f"Git diff (staged):\n{diff}"
    )
    return system, user


def call_groq(api_key, system, user, model=MODEL, temperature=0.3):
    payload = {
        "model": model,
        "temperature": temperature,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
    }
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        API_URL,
        data=data,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "User-Agent": f"gcm/{VERSION}",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            body = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "ignore")
        err(f"Groq API HTTP {e.code}: {detail[:300]}")
        if e.code == 429:
            print(c("  het quota/rate limit. Doi mot chut hoac xem: "
                    "https://console.groq.com/settings/limits", "90"),
                  file=sys.stderr)
        elif e.code in (401, 403):
            print(c("  key sai hoac het han. Tao key moi: "
                    "https://console.groq.com/keys", "90"), file=sys.stderr)
        elif e.code == 404:
            print(c(f"  model '{model}' khong ton tai. Xem model list: "
                    "https://console.groq.com/docs/models", "90"),
                  file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        err(f"loi mang: {e.reason}")
        print(c("  kiem tra ket noi internet/proxy roi thu lai.", "90"),
              file=sys.stderr)
        sys.exit(1)
    try:
        msg = body["choices"][0]["message"]["content"].strip()
    except (KeyError, IndexError):
        err("phan hoi API khong hop le: " + json.dumps(body)[:300])
        sys.exit(1)
    if msg.startswith("```"):
        lines = msg.splitlines()
        lines = [ln for ln in lines if not ln.strip().startswith("```")]
        msg = "\n".join(lines).strip()
    return msg


def commit_with_message(message, amend=False):
    """Commit voi message; tra returncode (0 = ok) de con push sau do."""
    args = ["git", "commit", "-F", "-"]
    if amend:
        args.append("--amend")
    res = subprocess.run(
        args, input=message, text=True,
        encoding="utf-8", errors="replace",
        cwd=REPO_ROOT,
    )
    return res.returncode


def branch_status():
    """Tra (branch, ahead): ahead = so commit chua push, None neu chua co upstream."""
    branch = run_git(["rev-parse", "--abbrev-ref", "HEAD"], check=False).strip()
    out = run_git(["rev-list", "--count", "@{u}..HEAD"], check=False).strip()
    ahead = int(out) if out.isdigit() else None
    return branch, ahead


def do_push():
    """git push; chua co upstream thi goi y push -u origin <branch>. True = ok."""
    print(c("Dang push...", "90"), file=sys.stderr)
    res = subprocess.run(
        ["git", "push"], cwd=REPO_ROOT,
        capture_output=True, text=True, encoding="utf-8", errors="replace",
    )
    out = (res.stdout + res.stderr).strip()
    if res.returncode == 0:
        print(out or "push xong.")
        return True
    if "--set-upstream" in out or "no upstream" in out:
        branch, _ = branch_status()
        try:
            ans = input(
                f"chua co upstream. Chay 'git push -u origin {branch}'? "
                + c("[Enter]", "1") + " dong y / " + c("[n]", "1") + " thoi: "
            ).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return False
        if ans in ("", "y", "yes"):
            res = subprocess.run(
                ["git", "push", "-u", "origin", branch], cwd=REPO_ROOT,
            )
            return res.returncode == 0
        return False
    err("push that bai:\n" + out)
    return False


def take_value(argv, *names):
    value, rest, i = None, [], 0
    while i < len(argv):
        a = argv[i]
        if a in names:
            if i + 1 >= len(argv):
                err(f"thieu gia tri cho {a} (vd: gcm {a} \"...\")")
                sys.exit(1)
            value = argv[i + 1]
            i += 2
            continue
        hit = next((n for n in names if a.startswith(n + "=")), None)
        if hit:
            value = a.split("=", 1)[1]
            i += 1
            continue
        rest.append(a)
        i += 1
    return value, rest


def edit_message(message):
    """Open the message in $EDITOR and return the edited text."""
    import tempfile
    editor = os.environ.get("EDITOR") or (
        "notepad" if os.name == "nt" else "nano"
    )
    with tempfile.NamedTemporaryFile(
        "w+", suffix=".gitcommit", delete=False
    ) as tf:
        tf.write(message)
        path = tf.name
    subprocess.run([editor, path])
    with open(path) as f:
        edited = f.read().strip()
    os.unlink(path)
    return edited


def self_update():
    """git pull trong thư mục cài gcm để lấy bản mới nhất."""
    src_dir = os.path.dirname(os.path.realpath(__file__))
    print(c(f"gcm v{VERSION} - cap nhat tai {src_dir} ...", "90"),
          file=sys.stderr)
    res = subprocess.run(
        ["git", "-C", src_dir, "pull", "--ff-only"],
        capture_output=True, text=True, encoding="utf-8", errors="replace",
    )
    out = (res.stdout + res.stderr).strip()
    if out:
        print(out)
    if res.returncode != 0:
        err(f'cap nhat that bai. Thu thu cong: git -C "{src_dir}" pull')
        sys.exit(1)
    print(c("gcm da o ban moi nhat.", "32"))
    sys.exit(0)


def main():
    for stream in (sys.stdout, sys.stderr):
        try:
            stream.reconfigure(encoding="utf-8")
        except (AttributeError, ValueError):
            pass

    argv = sys.argv[1:]
    if "-h" in argv or "--help" in argv:
        print(c(LOGO, "36"))
        print(c(f"  gcm v{VERSION} — by devduide", "1"))
        print(__doc__)
        return
    if "-v" in argv or "--version" in argv:
        print(f"gcm v{VERSION}")
        return
    if "-u" in argv or "--update" in argv or (argv and argv[0] == "update"):
        self_update()
    if argv and argv[0] == "config":
        show_config()
    hint, argv = take_value(argv, "-m", "--hint")
    model_override, argv = take_value(argv, "--model")
    print_only = "-p" in argv or "--print" in argv
    # ngon ngu: config lang=vi -> mac dinh --vi; --en de ep lai English
    vietnamese = (
        "--vi" in argv
        or (CONFIG.get("lang", "").lower() == "vi" and "--en" not in argv)
    )
    add_all = "-a" in argv or "--all" in argv
    select = "-s" in argv or "--select" in argv
    # tui: config tui=true -> mac dinh TUI; -s (nhap so) van uu tien hon
    tui = "-t" in argv or "--tui" in argv or (
        cfg_bool(CONFIG.get("tui", "")) and not select
    )
    auto_yes = "-y" in argv or "--yes" in argv
    amend = "--amend" in argv
    # push: --push hoac config push=always -> tu push sau commit
    push_cfg = CONFIG.get("push", "ask").lower()
    auto_push = "--push" in argv or push_cfg == "always"
    no_push = push_cfg == "never"
    model = model_override or MODEL

    ensure_repo()

    def pick(default_all=False):
        """Chọn file: TUI nếu -t và hỗ trợ được, ngược lại chế độ nhập số."""
        if tui and tui_supported():
            try:
                return tui_select(default_all)
            except (OSError, ImportError):
                print(c("(TUI loi, chuyen sang nhap so)", "90"), file=sys.stderr)
        elif tui:
            print(c("(terminal khong ho tro TUI, dung nhap so)", "90"),
                  file=sys.stderr)
        return select_files(default_all)

    if add_all:
        run_git(["add", "-A"])
    elif tui or select:
        pick()

    def load_staged():
        d = run_git(["diff", "--staged"])
        fs = [
            ln for ln in run_git(["diff", "--staged", "--name-only"]).splitlines()
            if ln.strip()
        ]
        return d, fs

    diff, files = load_staged()
    from_head = False  # --amend khong stage gi: lay diff tu HEAD

    if not diff.strip():
        status = run_git(["status", "--porcelain"]).strip()
        if amend:
            diff = run_git(["show", "--format=", "HEAD"])
            files = [
                ln for ln in
                run_git(["show", "--name-only", "--format=", "HEAD"]).splitlines()
                if ln.strip()
            ]
            from_head = True
            if not diff.strip():
                err("khong co commit nao de --amend.")
                sys.exit(1)
        elif not status:
            err("nothing to commit (working tree clean).")
            sys.exit(1)
        elif print_only:
            err("chua stage thay doi nao. Dung `git add` hoac `gcm -a`.")
            sys.exit(1)
        else:
            pick(default_all=True)
            diff, files = load_staged()
            if not diff.strip():
                err("chua co file nao duoc stage.")
                sys.exit(1)

    api_key = get_api_key()

    # smart diff: loai lockfile/binary, file qua lon thay bang --stat
    diff, skipped, truncated = smart_diff(files, from_head)
    if not diff.strip():
        # toan bo deu bi loai (vd chi commit lockfile) -> gui stat tong
        diff = file_stat(".", from_head)

    def generate(temperature):
        if not print_only:
            print(c("Dang sinh commit message...", "90"), file=sys.stderr)
        system, user = build_prompt(diff, files, vietnamese, hint, skipped)
        return call_groq(api_key, system, user, model, temperature)

    message = generate(0.3)

    if print_only:
        print(message)
        return

    def finish(want_push):
        rc = commit_with_message(message, amend)
        if rc != 0:
            sys.exit(rc)
        if want_push and not no_push:
            do_push()
        sys.exit(0)

    if auto_yes:
        finish(auto_push)

    branch, ahead = branch_status()
    branch_line = c(f"nhanh {branch}", "36") + (
        c(f"  ↑{ahead} chua push", "33") if ahead else ""
    )

    temperature = 0.3
    while True:
        print()
        print(branch_line)
        print(c("-" * 60, "90"))
        print(c(message, "32"))
        print(c("-" * 60, "90"))
        if truncated:
            print(c("(diff lon: mot phan chi gui thong ke --stat)", "90"))
        if skipped:
            print(c(f"(da loai khoi noi dung gui: {', '.join(skipped)})", "90"))

        action = " amend  " if amend else " commit  "
        prompt = c("[Enter]", "1") + action
        if not no_push:
            prompt += c("[p]", "1") + (" +push  " if amend else " commit+push  ")
        prompt += (
            c("[e]", "1") + " sua  "
            + c("[r]", "1") + " tao lai  "
            + c("[n]", "1") + " huy: "
        )
        try:
            choice = input(prompt).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(1)

        if choice == "n":
            print("Da huy.")
            sys.exit(0)
        if choice == "r":
            temperature = min(temperature + 0.3, 1.0)
            message = generate(temperature)
            continue
        if choice == "e":
            message = edit_message(message)
            if not message:
                err("message rong, da huy.")
                sys.exit(1)
        break

    finish(auto_push or choice == "p")


if __name__ == "__main__":
    main()
