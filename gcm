#!/usr/bin/env python3
"""gcm - Git Commit Message generator (free, via Groq API).

Reads your staged changes, asks an LLM for a Conventional Commits message,
prints it and lets you commit. No paid API needed (Groq free tier).

Usage:
  gcm                Generate message and ask to commit
  gcm -s             Chọn file để stage (interactive) rồi generate
  gcm -a             git add -A first, then generate
  gcm -m "hint"      Thêm ngữ cảnh/gợi ý cho message
  gcm -y             Commit luôn, không hỏi
  gcm --amend        Sửa (reword) commit gần nhất
  gcm --vi           Vietnamese commit message (default: English)
  gcm -p             Print message only (no prompt)
  gcm --model NAME   Đổi model cho lần chạy này
  gcm -h             Show help

Khi review: [Enter] commit · [e] sửa · [r] tạo lại · [n] hủy.
Nếu chưa stage gì mà working tree có thay đổi, gcm tự mở bộ chọn file.

Config:
  GROQ_API_KEY   API key (hoặc file ~/.config/gcm/config)
  GCM_MODEL      Đổi model mặc định (mặc định: llama-3.3-70b-versatile)
  Lấy key free tại https://console.groq.com/keys
"""
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request

API_URL = "https://api.groq.com/openai/v1/chat/completions"
MODEL = os.environ.get("GCM_MODEL", "llama-3.3-70b-versatile")
MAX_DIFF_CHARS = 12000
CONFIG_PATH = os.path.expanduser("~/.config/gcm/config")
REPO_ROOT = None  # gốc repo, set sau khi xác nhận đang trong git repo


# ---- small terminal color helpers ----
def c(text, code):
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"


def err(msg):
    print(c("error: ", "31") + msg, file=sys.stderr)


def run_git(args, check=True):
    """Run a git command, return stdout (stripped)."""
    res = subprocess.run(
        ["git"] + args,
        capture_output=True, text=True,
        encoding="utf-8", errors="replace",
        cwd=REPO_ROOT,  # luôn chạy từ gốc repo (path porcelain là root-relative)
    )
    if check and res.returncode != 0:
        err(res.stderr.strip() or f"git {' '.join(args)} failed")
        sys.exit(1)
    return res.stdout


def get_api_key():
    key = os.environ.get("GROQ_API_KEY", "").strip()
    if key:
        return key
    if os.path.exists(CONFIG_PATH):
        with open(CONFIG_PATH) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    # accept "KEY" or "GROQ_API_KEY=KEY"
                    return line.split("=", 1)[-1].strip()
    err("no Groq API key found.")
    print(
        "  Lấy key free tại: " + c("https://console.groq.com/keys", "36"),
        file=sys.stderr,
    )
    print("  Rồi chạy một trong hai cách:", file=sys.stderr)
    print('    export GROQ_API_KEY="gsk_..."   (thêm vào ~/.bashrc)', file=sys.stderr)
    print(f'    echo "gsk_..." > {CONFIG_PATH}', file=sys.stderr)
    sys.exit(1)


def ensure_repo():
    global REPO_ROOT
    res = subprocess.run(
        ["git", "rev-parse", "--is-inside-work-tree", "--show-toplevel"],
        capture_output=True, text=True,
        encoding="utf-8", errors="replace",
    )
    lines = res.stdout.splitlines()
    if res.returncode != 0 or not lines or lines[0].strip() != "true":
        err("không phải git repository (chạy trong thư mục repo).")
        sys.exit(1)
    # dòng 2 là đường dẫn gốc repo -> mọi lệnh git sau đều chạy từ đây
    REPO_ROOT = lines[1].strip() if len(lines) > 1 else None


def changed_files():
    """Trả về list (code, path) các file có thay đổi (git status porcelain).

    Dùng -uall để folder mới được liệt kê thành từng file thay vì gộp 'folder/'.
    """
    items = []
    for line in run_git(["status", "--porcelain", "-uall"]).splitlines():
        if not line.strip():
            continue
        code = line[:2]
        rest = line[3:]
        if " -> " in rest:  # rename: lấy tên mới
            rest = rest.split(" -> ", 1)[1]
        rest = rest.strip()
        if len(rest) >= 2 and rest[0] == '"' and rest[-1] == '"':
            # git bọc nháy cho path có ký tự đặc biệt
            rest = rest[1:-1].encode().decode("unicode_escape")
        items.append((code, rest))
    return items


def status_label(code):
    """Nhãn trạng thái ngắn, có màu, từ 2 ký tự porcelain."""
    if code == "??":
        return c("new      ", "36")
    flags = code.replace(" ", "")
    if "D" in flags:
        return c("deleted  ", "31")
    if "R" in flags:
        return c("renamed  ", "35")
    if "A" in flags:
        return c("added    ", "32")
    if "M" in flags:
        return c("modified ", "33")
    return c(code.ljust(9), "90")


def parse_selection(raw, n):
    """Parse '1 3', '1-3', '2,4' -> list số thứ tự hợp lệ (1..n)."""
    chosen = set()
    for tok in raw.replace(",", " ").split():
        if "-" in tok:
            a, _, b = tok.partition("-")
            if a.isdigit() and b.isdigit():
                for k in range(int(a), int(b) + 1):
                    if 1 <= k <= n:
                        chosen.add(k)
        elif tok.isdigit():
            k = int(tok)
            if 1 <= k <= n:
                chosen.add(k)
    return sorted(chosen)


def select_files(default_all=False):
    """Hiện danh sách file thay đổi, cho chọn để git add. True nếu đã stage.

    default_all=True: Enter (để trống) = stage tất cả (tiện khi tự bật picker).
    Ngược lại Enter = giữ nguyên staging hiện tại.
    """
    items = changed_files()
    if not items:
        return False
    n = len(items)
    print(c(f"Chọn file để stage ({n} thay đổi):", "1"))
    for i, (code, path) in enumerate(items, 1):
        staged = code[0] not in " ?"
        mark = c("●", "32") if staged else c("○", "90")
        print(f"  {mark} {c(str(i).rjust(2) + '.', '1')} {status_label(code)} {path}")
    enter_hint = "Enter = tất cả" if default_all else "Enter = giữ nguyên"
    print(c(
        f"  số ('1 3', '1-3') · 'a' tất cả · {enter_hint} · 'q' hủy",
        "90",
    ))
    try:
        raw = input(c("> ", "1")).strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(1)

    if raw in ("q", "quit", "n"):
        print("Đã hủy.")
        sys.exit(0)
    if raw == "" and not default_all:
        return False  # giữ nguyên staging hiện tại
    if raw in ("a", "all") or (raw == "" and default_all):
        sel = list(range(1, n + 1))
    else:
        sel = parse_selection(raw, n)
    if not sel:
        err("không chọn file nào hợp lệ.")
        sys.exit(1)
    paths = [items[i - 1][1] for i in sel]
    run_git(["add", "--"] + paths)
    print(c(f"đã stage {len(paths)} file.", "32"))
    return True


def build_prompt(diff, files, vietnamese, hint=None):
    lang = (
        "Viết bằng TIẾNG VIỆT." if vietnamese
        else "Write in ENGLISH."
    )
    files_list = "\n".join(files) if files else "(unknown)"
    system = (
        "You are an expert developer writing git commit messages. "
        "Follow the Conventional Commits spec strictly: "
        "type(scope): short summary in imperative mood. "
        "Allowed types: feat, fix, docs, style, refactor, perf, test, "
        "build, ci, chore, revert. "
        "The summary line (lowercase after the colon, no trailing period) must "
        "cover the MAIN changes, not just one. When the diff does several "
        "significant things, string them together concisely in the summary "
        "(e.g. 'update width and drop Height/Lib/Id params') instead of naming "
        "only one. Keep it readable: aim for <= 72 chars, but you may go a "
        "little longer when needed to cover the key changes. "
        "Then add a blank line and a DETAILED body of 2-5 bullets (each "
        "starting with '- ') describing the concrete sub-changes in the diff. "
        "Every bullet must be SPECIFIC and grounded in the actual diff: name "
        "the component, function, file, prop or value involved and state what "
        "exactly changed (e.g. old -> new value) or why it was needed. "
        "Cover the meaningful changes, not just one. "
        "Do NOT invent changes that are not in the diff, do NOT restate the "
        "summary, and do NOT pad with vague filler like 'for better "
        "visibility', 'for simplicity', 'for readability', 'improve user "
        "experience' unless tied to a concrete, real reason. "
        "Omit the body only for a truly trivial one-line change (typo, bump). "
        f"{lang} "
        "Output ONLY the commit message, no markdown fences, no preamble."
    )
    hint_block = (
        f"Extra context from the author (use it, it is important):\n{hint}\n\n"
        if hint else ""
    )
    user = (
        f"{hint_block}"
        f"Changed files:\n{files_list}\n\n"
        f"Git diff (staged):\n{diff}"
    )
    return system, user


def call_groq(api_key, system, user, model=MODEL, temperature=0.3):
    payload = {
        "model": model,
        "temperature": temperature,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
    }
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        API_URL,
        data=data,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "User-Agent": "gcm/1.0",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            body = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "ignore")
        err(f"Groq API HTTP {e.code}: {detail[:300]}")
        sys.exit(1)
    except urllib.error.URLError as e:
        err(f"lỗi mạng: {e.reason}")
        sys.exit(1)
    try:
        msg = body["choices"][0]["message"]["content"].strip()
    except (KeyError, IndexError):
        err("phản hồi API không hợp lệ: " + json.dumps(body)[:300])
        sys.exit(1)
    # strip accidental code fences
    if msg.startswith("```"):
        lines = msg.splitlines()
        lines = [ln for ln in lines if not ln.strip().startswith("```")]
        msg = "\n".join(lines).strip()
    return msg


def commit_with_message(message, amend=False):
    args = ["git", "commit", "-F", "-"]
    if amend:
        args.append("--amend")
    res = subprocess.run(
        args, input=message, text=True,
        encoding="utf-8", errors="replace",
        cwd=REPO_ROOT,
    )
    sys.exit(res.returncode)


def take_value(argv, *names):
    """Tách option có giá trị ('-m hint' hoặc '--hint=hint').

    Trả về (value | None, argv_còn_lại).
    """
    value, rest, i = None, [], 0
    while i < len(argv):
        a = argv[i]
        if a in names and i + 1 < len(argv):
            value = argv[i + 1]
            i += 2
            continue
        hit = next((n for n in names if a.startswith(n + "=")), None)
        if hit:
            value = a.split("=", 1)[1]
            i += 1
            continue
        rest.append(a)
        i += 1
    return value, rest


def edit_message(message):
    """Open the message in $EDITOR and return the edited text."""
    import tempfile
    editor = os.environ.get("EDITOR", "nano")
    with tempfile.NamedTemporaryFile(
        "w+", suffix=".gitcommit", delete=False
    ) as tf:
        tf.write(message)
        path = tf.name
    subprocess.run([editor, path])
    with open(path) as f:
        edited = f.read().strip()
    os.unlink(path)
    return edited


def main():
    # Windows: console mặc định cp1252 -> ép UTF-8 để in/đọc không lỗi
    for stream in (sys.stdout, sys.stderr):
        try:
            stream.reconfigure(encoding="utf-8")
        except (AttributeError, ValueError):
            pass

    argv = sys.argv[1:]
    if "-h" in argv or "--help" in argv:
        print(__doc__)
        return
    hint, argv = take_value(argv, "-m", "--hint")
    model_override, argv = take_value(argv, "--model")
    print_only = "-p" in argv or "--print" in argv
    vietnamese = "--vi" in argv
    add_all = "-a" in argv or "--all" in argv
    select = "-s" in argv or "--select" in argv
    auto_yes = "-y" in argv or "--yes" in argv
    amend = "--amend" in argv
    model = model_override or MODEL

    ensure_repo()

    if add_all:
        run_git(["add", "-A"])
    elif select:
        select_files()

    def load_staged():
        d = run_git(["diff", "--staged"])
        fs = [
            ln for ln in run_git(["diff", "--staged", "--name-only"]).splitlines()
            if ln.strip()
        ]
        return d, fs

    diff, files = load_staged()

    if not diff.strip():
        status = run_git(["status", "--porcelain"]).strip()
        if amend:
            # reword commit gần nhất: dùng diff của chính commit đó làm ngữ cảnh
            diff = run_git(["show", "--format=", "HEAD"])
            files = [
                ln for ln in
                run_git(["show", "--name-only", "--format=", "HEAD"]).splitlines()
                if ln.strip()
            ]
            if not diff.strip():
                err("không có commit nào để --amend.")
                sys.exit(1)
        elif not status:
            err("nothing to commit (working tree clean).")
            sys.exit(1)
        elif print_only:
            err("chưa stage thay đổi nào. Dùng `git add` hoặc `gcm -a`.")
            sys.exit(1)
        else:
            # tự mở bộ chọn file thay vì báo lỗi (Enter = stage tất cả)
            select_files(default_all=True)
            diff, files = load_staged()
            if not diff.strip():
                err("chưa có file nào được stage.")
                sys.exit(1)

    api_key = get_api_key()

    truncated = len(diff) > MAX_DIFF_CHARS
    if truncated:
        diff = diff[:MAX_DIFF_CHARS] + "\n...[diff truncated]..."

    def generate(temperature):
        if not print_only:
            print(c("Đang sinh commit message...", "90"), file=sys.stderr)
        system, user = build_prompt(diff, files, vietnamese, hint)
        return call_groq(api_key, system, user, model, temperature)

    message = generate(0.3)

    if print_only:
        print(message)
        return

    if auto_yes:
        commit_with_message(message, amend)
        return  # commit_with_message gọi sys.exit

    temperature = 0.3
    while True:
        print()
        print(c("─" * 60, "90"))
        print(c(message, "32"))
        print(c("─" * 60, "90"))
        if truncated:
            print(c("(diff lớn nên đã được cắt bớt khi gửi)", "90"))

        prompt = (
            c("[Enter]", "1") + (" amend  " if amend else " commit  ")
            + c("[e]", "1") + " sửa  "
            + c("[r]", "1") + " tạo lại  "
            + c("[n]", "1") + " hủy: "
        )
        try:
            choice = input(prompt).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(1)

        if choice == "n":
            print("Đã hủy.")
            sys.exit(0)
        if choice == "r":
            temperature = min(temperature + 0.3, 1.0)
            message = generate(temperature)
            continue
        if choice == "e":
            message = edit_message(message)
            if not message:
                err("message rỗng, đã hủy.")
                sys.exit(1)
        break

    commit_with_message(message, amend)


if __name__ == "__main__":
    main()
